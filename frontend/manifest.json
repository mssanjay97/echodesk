{
  "manifest_version": 3,
  "name": "URL History Tracker",
  "version": "1.0",
  "description": "Stores all visited URLs with React",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts"
  }
}
